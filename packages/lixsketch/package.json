{
  "name": "@elixpo/lixsketch",
  "version": "5.5.0",
  "description": "Open-source SVG whiteboard engine + React canvas component with hand-drawn aesthetics — the core of LixSketch",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./react": {
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react/styles": {
      "style": "./dist/react/styles.css",
      "default": "./dist/react/styles.css"
    },
    "./src/*": "./src/*",
    "./fonts": "./fonts/fonts.css",
    "./fonts/*": "./fonts/*"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src/",
    "dist/",
    "fonts/",
    "README.md"
  ],
  "keywords": [
    "whiteboard",
    "canvas",
    "svg",
    "diagram",
    "drawing",
    "roughjs",
    "sketch",
    "excalidraw-alternative",
    "infinite-canvas",
    "framework",
    "react"
  ],
  "author": {
    "name": "Ayushman Bhattacharya",
    "email": "ayushman@myceli.ai",
    "url": "https://github.com/elixpo"
  },
  "license": "MIT",
  "homepage": "https://sketch.elixpo.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/elixpo/sketch.elixpo.git",
    "directory": "packages/lixsketch"
  },
  "bugs": {
    "url": "https://github.com/elixpo/sketch.elixpo/issues"
  },
  "dependencies": {
    "roughjs": "^4.6.6",
    "perfect-freehand": "^1.2.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build"
  }
}
