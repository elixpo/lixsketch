{
  "name": "lixsketch",
  "displayName": "LixSketch",
  "description": "Open-source whiteboard diagrams inside VS Code — draw, sketch, and save .lixsketch files",
  "version": "5.4.3",
  "author": {
    "name": "Ayushman Bhattacharya",
    "email": "ayushman@myceli.ai",
    "url": "https://github.com/elixpo"
  },
  "publisher": "elixpo",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "whiteboard",
    "diagram",
    "sketch",
    "drawing",
    "canvas",
    "svg",
    "excalidraw"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "lixsketch.editor",
        "displayName": "LixSketch Editor",
        "selector": [
          {
            "filenamePattern": "*.lixsketch"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "lixsketch.newDiagram",
        "title": "LixSketch: New Diagram"
      }
    ],
    "iconThemes": [
      {
        "id": "lixsketch-icons",
        "label": "LixSketch File Icons",
        "path": "./media/file-icon-theme.json"
      }
    ],
    "languages": [
      {
        "id": "lixsketch",
        "extensions": [
          ".lixsketch"
        ],
        "icon": {
          "light": "./media/file-icon.png",
          "dark": "./media/file-icon.png"
        }
      }
    ]
  },
  "scripts": {
    "build:engine": "node esbuild.config.js",
    "build:extension": "node esbuild.extension.js",
    "build": "npm run build:engine && npm run build:extension",
    "watch": "npm run build -- --watch",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "@vscode/vsce": "^2.24.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elixpo/sketch.elixpo.git",
    "directory": "packages/vscode"
  },
  "license": "MIT"
}
